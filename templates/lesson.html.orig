<!DOCTYPE html>
<html>
<head>
    <title>{{ lesson.subject }} - {{ lesson.topic }}</title>
    <style>
        body { font-family: Arial; background: #0f0f0f; color: white; padding: 20px; }
        .container { max-width: 900px; margin: 0 auto; }
        h1 { color: #ffcc00; }
        .video-list { margin-top: 20px; }
        video { width: 100%; max-width: 800px; display: block; margin: 10px auto; }
        .homework { background: #1e1e1e; padding: 15px; border-radius: 8px; margin-top: 20px; }
        .back-link { display: block; margin-top: 20px; color: #4da6ff; }
    </style>
</head>
<body>
    <div class="container">
        <h1>{{ lesson.subject }} - {{ lesson.topic }}</h1>
        <p><strong>День:</strong> {{ lesson.day.name }}, урок №{{ lesson.lesson_number }}</p>

{% if lesson.videos %}
<h2>Видеоуроки по теме</h2>
<div class="video-list">
    <ul>
        {% for video in lesson.videos|sort(attribute='order') %}
        <li>
            <a href="#" class="video-link" data-video-id="{{ video.video_id }}">{{ video.title }}</a>
        </li>
        {% endfor %}
    </ul>
</div>

<div id="video-player-container" style="display: none; margin-top: 20px;">
    <video id="video-player" controls width="800">
        <source src="" type="video/mp4">
    </video>
</div>

<script>
    const videoContainer = document.getElementById('video-player-container');
    const videoPlayer = document.getElementById('video-player');
    const videoSource = videoPlayer.querySelector('source');

    document.querySelectorAll('.video-link').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const videoId = link.dataset.videoId;
            videoSource.src = `/proxy/${videoId}`;
            videoPlayer.load();  // загружаем новый источник
            videoContainer.style.display = 'block';
            // Можно автоматически начать воспроизведение
            videoPlayer.play().catch(e => console.log('Autoplay failed', e));
        });
    });
</script>
{% endif %}

        {% if lesson.homework %}
        <div class="homework">
            <h2>Домашнее задание</h2>
            <p>{{ lesson.homework }}</p>
        </div>
        {% endif %}

        <a href="{{ url_for('home') }}" class="back-link">← Назад к расписанию</a>
    </div>
</body>
</html>
